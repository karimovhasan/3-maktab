rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, ['admin', 'teacher', 'student', 'parent'])
    //   - createdAt: timestamp (required)
    //
    // Collection: news
    // Document ID: {newsId}
    // Fields:
    //   - title: string (required)
    //   - content: string (required)
    //   - image: string (optional)
    //   - authorId: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "hasankarimov023@gmail.com" ||
         request.auth.token.email == "admin@maktab3.uz" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && isOwner(userId);
      allow delete: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if true; // Temporarily allowed to bypass auth issues
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow write: if true; // Temporarily allowed to bypass auth issues
    }
  }
}
